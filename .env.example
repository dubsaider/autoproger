# Репозиторий (GitHub / GitLab) — можно настроить в админ-панели
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_TOKEN=ghp_xxxx
GITLAB_TOKEN=glpat-xxxx
REPO_PATH=./repos

# Автор коммитов
GIT_AUTHOR_NAME=Autoproger Bot
GIT_AUTHOR_EMAIL=username@users.noreply.github.com

# LLM для анализа и планов: cursor (локальный Cursor CLI) | claude | none
LLM_PROVIDER=cursor
CURSOR_CLI_CMD=cursor agent
CURSOR_TIMEOUT_SEC=120

# Claude (если LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Проверка актуальности issue через LLM (по меткам всегда)
# ACTUALITY_CHECK_LLM=false

# Админ-панель (обязательно задать в продакшене)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_SECRET_KEY=generate-with-openssl-rand-hex-32
