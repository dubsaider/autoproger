# =============================================================================
# Autoproger v2 Configuration
# =============================================================================

# --- LLM Provider ---
# Primary: Claude Code CLI (no API key needed — uses your Claude subscription)
LLM_DEFAULT_PROVIDER=claude_code
CLAUDE_CODE_BINARY=claude
CLAUDE_CODE_MAX_TURNS=15
CLAUDE_CODE_TIMEOUT=600
# Max cost per invocation (0 = unlimited)
CLAUDE_CODE_MAX_BUDGET_USD=0
# Override model (empty = Claude Code default, e.g. "sonnet" or "opus")
CLAUDE_CODE_MODEL=

# Fallback: Anthropic API (optional)
ANTHROPIC_API_KEY=
# Fallback: OpenRouter (optional)
OPENROUTER_API_KEY=
# Model for API-based providers
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/autoproger.db

# --- Auth ---
SECRET_KEY=change-me-to-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- GitHub ---
GITHUB_TOKEN=
# --- GitLab ---
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

# --- General ---
WORKDIR=./data/repos
LOG_LEVEL=INFO
